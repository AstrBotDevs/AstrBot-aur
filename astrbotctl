#!/bin/sh
set -e

# Constants
SYSTEM_ROOT="/var/lib/astrbot"
CONFIG_DIR="/etc/astrbot"
APP_DIR="/opt/astrbot"
CACHE_DIR="/var/cache/astrbot"
UPSTREAM_URL="https://github.com/AstrBotDevs/AstrBot.git"
UPSTREAM_BRANCH="dev"

cmd="$1"
instance="$2"

require_root() {
    [ "$(id -u)" -ne 0 ] && {
        echo "❌ Need root"
        exit 1
    }
}

require_instance() {
    [ -z "$instance" ] && {
        echo "Usage: astrbotctl <cmd> <instance>"
        exit 1
    }
}

conf_file() {
    echo "$CONFIG_DIR/$instance.conf"
}

venv_dir() {
    echo "$CACHE_DIR/venv-$instance"
}

print_help() {
    cat <<EOF
astrbotctl - management helper for AstrBot instances

Usage:
  astrbotctl init <name>          Initialize a new instance (create data directory and config)
  astrbotctl run <name> [args...] Start an instance (for systemd this is used by the service)
  astrbotctl cli <name> [args...] Run a CLI command against the instance
  astrbotctl paths <name>         Print all instance-related paths (config, data, venv, logs, etc)
  astrbotctl rm <name>            Remove instance data, config and venv
  astrbotctl list                 List known instances
  astrbotctl start|stop|restart|status <name>  Control systemd unit
  astrbotctl git                  Update packaged app source in /opt/astrbot
  astrbotctl reset <name>         Recreate instance config from template (keeps same PORT/ROOT if present)
  astrbotctl help|-h              Show this help text

Notes:
  - Reset only regenerates the config file from the bundled template.
  - Use 'reset' when you want to restore defaults from the template while preserving
    instance identity (PORT/ASTRBOT_ROOT) where possible.
EOF
}

# Initialize / ensure virtualenv and run astrbot with the provided config
run_astrbot() {
    VENV="$(venv_dir)"
    CONF="$(conf_file)"

    if [ ! -x "$VENV/bin/astrbot" ]; then
        echo ">>> init venv"
        uv venv "$VENV" --python 3.12
        "$VENV/bin/pip" install "$APP_DIR"
    fi

    # Exec the astrbot binary and pass the instance config file first,
    # then any additional args (e.g. "run", etc).
    exec "$VENV/bin/astrbot" -c "$CONF" "$@"
}

# Render config.template into the instance config.
# Behavior:
# - If an existing config exists, try to preserve PORT, HOST, and ASTRBOT_ROOT.
# - Otherwise, supply sensible defaults (ASTRBOT_ROOT=/var/lib/astrbot/<instance>, HOST=0.0.0.0,
#   PORT: pick the next free starting from 3000).
render_config_from_template() {
    CONF="$(conf_file)"
    TEMPLATE="$APP_DIR/config.template"
    # fallback paths for template
    if [ ! -f "$TEMPLATE" ]; then
        # try relative to script location (useful during development)
        HERE="$(cd "$(dirname "$0")" >/dev/null 2>&1 && pwd || printf "%s" ".")"
        if [ -f "$HERE/../config.template" ]; then
            TEMPLATE="$HERE/../config.template"
        elif [ -f "$HERE/config.template" ]; then
            TEMPLATE="$HERE/config.template"
        fi
    fi

    [ -f "$TEMPLATE" ] || {
        echo "❌ config template not found (looked in $APP_DIR and script paths)"
        return 1
    }

    # Preserve existing values if possible
    EXISTING_PORT=""
    EXISTING_HOST=""
    EXISTING_ROOT=""

    if [ -f "$CONF" ]; then
        EXISTING_PORT=$(awk -F= '/^PORT=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" 2>/dev/null || true)
        EXISTING_HOST=$(awk -F= '/^HOST=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" 2>/dev/null || true)
        EXISTING_ROOT=$(awk -F= '/^ASTRBOT_ROOT=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" 2>/dev/null || true)
    fi

    INSTANCE_NAME="$instance"
    ASTRBOT_ROOT="${EXISTING_ROOT:-$SYSTEM_ROOT/$instance}"
    HOST="${EXISTING_HOST:-0.0.0.0}"

    if [ -n "$EXISTING_PORT" ]; then
        PORT="$EXISTING_PORT"
    else
        # pick a free port starting at 3000
        PORT=3000
        while ss -lnt 2>/dev/null | grep -q ":$PORT "; do
            PORT=$((PORT + 1))
        done
    fi

    # Use sed to substitute common placeholders in the template.
    # Replace patterns like ${INSTANCE_NAME}, ${INSTANCE_NAME:-...}, etc.
    # We deliberately only replace a few common keys to avoid breaking the template.
    TMP_CONF="$(mktemp /tmp/astrbot.conf.XXXXXX)"
    # Ensure TMP_CONF is removed on exit/error
    trap 'rm -f "$TMP_CONF"' EXIT

    # Read template and perform replacements
    sed -E \
        -e "s/\\$\\{INSTANCE_NAME(:-[^}]*)?\\}/$INSTANCE_NAME/g" \
        -e "s/\\$\\{PORT(:-[^}]*)?\\}/$PORT/g" \
        -e "s/\\$\\{ASTRBOT_ROOT(:-[^}]*)?\\}/$ASTRBOT_ROOT/g" \
        -e "s/\\$\\{HOST(:-[^}]*)?\\}/$HOST/g" \
        "$TEMPLATE" >"$TMP_CONF"

    # Add a header comment with provenance
    {
        printf "# Generated by astrbotctl reset on %s\n" "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
        printf "# Instance: %s\n\n" "$instance"
        cat "$TMP_CONF"
    } >"${TMP_CONF}.hdr"

    install -Dm644 "${TMP_CONF}.hdr" "$CONF"
    # Make sure file ownership is sensible
    chown root:root "$CONF" 2>/dev/null || true
    chmod 644 "$CONF" 2>/dev/null || true

    rm -f "${TMP_CONF}.hdr"
    rm -f "$TMP_CONF"
    trap - EXIT

    echo "✅ config reset to template: $CONF (PORT=$PORT, HOST=$HOST, ASTRBOT_ROOT=$ASTRBOT_ROOT)"
    return 0
}

# Print all instance-related paths in a stable, machine-friendly format.
# Useful for scripts that need to locate files for an instance.
print_paths() {
    require_instance

    CONF="$(conf_file)"
    VENV="$(venv_dir)"
    ROOT="${SYSTEM_ROOT}/${instance}"
    HOME_DIR="${ROOT}/home"
    UV_CACHE_DIR="${CACHE_DIR}/uv"
    PYTHON_INSTALL_DIR="${CACHE_DIR}/python"
    LOG_DIR=""
    DASHBOARD_DIR=""
    WORKING_DIR="${HOME_DIR}" # matches systemd unit WorkingDirectory
    SYSTEMD_UNIT="astrbot@${instance}.service"

    # If config exists, try to extract values that override defaults.
    if [ -f "$CONF" ]; then
        # extract ASTRBOT_ROOT, LOG_DIR, ASTRBOT_PORT, ASTRBOT_HOST
        ASTRBOT_ROOT_CONF=$(awk -F= '/^ASTRBOT_ROOT=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" 2>/dev/null || true)
        [ -n "$ASTRBOT_ROOT_CONF" ] && ROOT="$ASTRBOT_ROOT_CONF" && HOME_DIR="${ROOT}/home" && WORKING_DIR="${HOME_DIR}"
        LOG_DIR=$(awk -F= '/^LOG_DIR=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" 2>/dev/null || true)
        # if LOG_DIR not set use default under root
        [ -z "$LOG_DIR" ] && LOG_DIR="${ROOT}/logs"
        DASHBOARD_DIR=$(awk -F= '/^ASTRBOT_DASHBOARD_ENABLE=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" 2>/dev/null || true)
        # Extract PORT/HOST for informational output
        PORT=$(awk -F= '/^PORT=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" 2>/dev/null || true)
        HOST=$(awk -F= '/^HOST=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" 2>/dev/null || true)
    else
        LOG_DIR="${ROOT}/logs"
        PORT=""
        HOST=""
    fi

    # canonicalize empty values
    PORT=${PORT:-}
    HOST=${HOST:-}

    # Print in KEY=value lines for easy parsing by scripts; also show human-friendly comment lines
    echo "# Instance: $instance"
    echo "INSTANCE_NAME=$instance"
    echo "SYSTEM_ROOT=$SYSTEM_ROOT"
    echo "ASTRBOT_ROOT=$ROOT"
    echo "HOME_DIR=$HOME_DIR"
    echo "WORKING_DIR=$WORKING_DIR"
    echo "CONFIG_FILE=$CONF"
    echo "VENV_DIR=$VENV"
    echo "CACHE_DIR=$CACHE_DIR"
    echo "UV_CACHE_DIR=$UV_CACHE_DIR"
    echo "PYTHON_INSTALL_DIR=$PYTHON_INSTALL_DIR"
    echo "LOG_DIR=$LOG_DIR"
    echo "APP_DIR=$APP_DIR"
    echo "SYSTEMD_UNIT=$SYSTEMD_UNIT"
    [ -n "$HOST" ] && echo "HOST=$HOST" || echo "HOST="
    [ -n "$PORT" ] && echo "PORT=$PORT" || echo "PORT="
    # Provide a short note about dashboard enablement (if present in config)
    if [ -n "$DASHBOARD_DIR" ]; then
        echo "ASTRBOT_DASHBOARD_ENABLE=$DASHBOARD_DIR"
    fi
    return 0
}

case "$cmd" in

help)
    print_help
    ;;

init)
    require_root
    require_instance

    ROOT="$SYSTEM_ROOT/$instance"
    CONF="$(conf_file)"

    [ -d "$ROOT" ] && {
        echo "❌ exists"
        exit 1
    }

    install -dm755 -o astrbot -g astrbot "$ROOT"

    PORT=3000
    while ss -lnt | grep -q ":$PORT "; do
        PORT=$((PORT + 1))
    done

    cat >"$CONF" <<EOF
INSTANCE_NAME="$instance"
ASTRBOT_ROOT="$ROOT"
PORT="$PORT"
HOST="0.0.0.0"
EOF

    echo "✅ init done ($PORT)"
    ;;

# Reset: regenerate the instance config from the template, preserving sensible values
reset)
    require_root
    require_instance

    if render_config_from_template; then
        # optionally reload systemd unit if active (don't fail on non-systemd env)
        if command -v systemctl >/dev/null 2>&1; then
            systemctl try-reload-or-restart "astrbot@$instance" 2>/dev/null || true
        fi
        exit 0
    else
        echo "❌ reset failed"
        exit 1
    fi
    ;;

# Restore the older-style startup display: show instance, host and port.
# The actual start will pass the configuration file to the astrbot binary.
run)
    require_instance

    CONF="$(conf_file)"

    # Extract PORT and HOST from the config file without sourcing (safer).
    if [ -f "$CONF" ]; then
        PORT=$(awk -F= '/^PORT=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" || true)
        HOST=$(awk -F= '/^HOST=/{ val=$2; sub(/^[ \t]*"/,"",val); sub(/"$/,"",val); print val; exit }' "$CONF" || true)
    fi

    PORT=${PORT:-unknown}
    HOST=${HOST:-0.0.0.0}

    echo ">>> Starting AstrBot instance: $instance"
    echo ">>> Host: $HOST"
    echo ">>> Port: $PORT"
    echo ">>> Using config: $CONF"

    shift 2
    run_astrbot run "$@"
    ;;

# CLI mode — preserve behavior but show a compact header similar to older versions.
cli)
    require_instance

    CONF="$(conf_file)"
    echo ">>> AstrBot CLI for instance: $instance"
    echo ">>> Using config: $CONF"

    shift 2
    run_astrbot "$@"
    ;;

# New: print all paths related to an instance
paths)
    require_instance
    print_paths
    ;;

# New: reset subcommand - regenerate config from template
rm)
    require_root
    require_instance

    systemctl stop "astrbot@$instance" 2>/dev/null || true
    systemctl disable "astrbot@$instance" 2>/dev/null || true

    rm -rf "$SYSTEM_ROOT/$instance"
    rm -f "$(conf_file)"
    rm -rf "$(venv_dir)"

    echo "✅ removed"
    ;;

list)
    ls -1 "$SYSTEM_ROOT" 2>/dev/null || true
    ;;

start | stop | restart | status)
    require_instance
    systemctl "$cmd" "astrbot@$instance"
    ;;

git)
    require_root

    git -C "$APP_DIR" init 2>/dev/null || true
    git -C "$APP_DIR" remote add origin "$UPSTREAM_URL" 2>/dev/null || true

    git -C "$APP_DIR" fetch --depth=1 origin "$UPSTREAM_BRANCH"
    git -C "$APP_DIR" checkout -f "$UPSTREAM_BRANCH"

    echo "✅ updated"
    ;;

help | -h)
    print_help
    ;;

*)
    print_help
    ;;
esac
