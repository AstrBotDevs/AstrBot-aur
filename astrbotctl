#!/bin/sh
set -e

# Constants
SYSTEM_ROOT="/var/lib/astrbot"
CONFIG_DIR="/etc/astrbot"
APP_DIR="/opt/astrbot"
CACHE_DIR="/var/cache/astrbot"
UPSTREAM_URL="https://github.com/AstrBotDevs/AstrBot.git"
UPSTREAM_BRANCH="dev"

cmd="$1"
instance="$2"

require_root() {
    [ "$(id -u)" -ne 0 ] && {
        echo "❌ Need root"
        exit 1
    }
}

require_instance() {
    [ -z "$instance" ] && {
        echo "Usage: astrbotctl <cmd> <instance>"
        exit 1
    }
}

conf_file() {
    echo "$CONFIG_DIR/$instance.conf"
}

venv_dir() {
    echo "$CACHE_DIR/venv-$instance"
}

run_astrbot() {
    VENV="$(venv_dir)"
    CONF="$(conf_file)"

    if [ ! -x "$VENV/bin/astrbot" ]; then
        echo ">>> init venv"
        uv venv "$VENV" --python 3.12
        "$VENV/bin/pip" install "$APP_DIR"
    fi

    exec "$VENV/bin/astrbot" -c "$CONF" "$@"
}

case "$cmd" in

init)
    require_root
    require_instance

    ROOT="$SYSTEM_ROOT/$instance"
    CONF="$(conf_file)"

    [ -d "$ROOT" ] && {
        echo "❌ exists"
        exit 1
    }

    install -dm755 -o astrbot -g astrbot "$ROOT"

    PORT=3000
    while ss -lnt | grep -q ":$PORT "; do
        PORT=$((PORT + 1))
    done

    cat >"$CONF" <<EOF
INSTANCE_NAME="$instance"
ASTRBOT_ROOT="$ROOT"
PORT="$PORT"
HOST="0.0.0.0"
EOF

    echo "✅ init done ($PORT)"
    ;;

run)
    require_instance
    shift 2
    run_astrbot run "$@"
    ;;

cli)
    require_instance
    shift 2
    run_astrbot "$@"
    ;;

rm)
    require_root
    require_instance

    systemctl stop "astrbot@$instance" 2>/dev/null || true
    systemctl disable "astrbot@$instance" 2>/dev/null || true

    rm -rf "$SYSTEM_ROOT/$instance"
    rm -f "$(conf_file)"
    rm -rf "$(venv_dir)"

    echo "✅ removed"
    ;;

list)
    ls -1 "$SYSTEM_ROOT" 2>/dev/null || true
    ;;

start | stop | restart | status)
    require_instance
    systemctl "$cmd" "astrbot@$instance"
    ;;

git)
    require_root

    git -C "$APP_DIR" init 2>/dev/null || true
    git -C "$APP_DIR" remote add origin "$UPSTREAM_URL" 2>/dev/null || true

    git -C "$APP_DIR" fetch --depth=1 origin "$UPSTREAM_BRANCH"
    git -C "$APP_DIR" checkout -f "$UPSTREAM_BRANCH"

    echo "✅ updated"
    ;;

*)
    echo "Usage:"
    echo "  astrbotctl init <name>"
    echo "  astrbotctl run <name>"
    echo "  astrbotctl rm <name>"
    echo "  astrbotctl list"
    echo "  astrbotctl start|stop|status <name>"
    ;;
esac
